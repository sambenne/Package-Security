{
    "name": "sambenne/package-security",
    "description": "A Laravel dependency risk gate for Composer and npm packages.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Sambenne\\PackageSecurity\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sambenne\\PackageSecurity\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "symfony/process": "^6.4|^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "bin": [
        "bin/package-security"
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Sambenne\\PackageSecurity\\PackageSecurityServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
